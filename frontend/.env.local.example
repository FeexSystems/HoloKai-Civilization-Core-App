# HoloKai frontend ↔ Python Civilization Core

# Prefer same-origin proxy (default). Next.js rewrites /backend/* → FastAPI.
# Leave unset to use /backend
# NEXT_PUBLIC_API_URL=/backend

# Or talk to FastAPI directly (needs CORS):
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side rewrite target (Next.js only)
BACKEND_URL=http://127.0.0.1:8000

# Ollama (Vanguard persona voice + optional local embeddings)
NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434
NEXT_PUBLIC_OLLAMA_MODEL=qwen3:32b

# Server-side RAG (Next.js API routes)
OLLAMA_URL=http://localhost:11434
HOLAKAI_EMBED_MODEL=nomic-embed-text
HOLAKAI_VECTOR_BACKEND=local
