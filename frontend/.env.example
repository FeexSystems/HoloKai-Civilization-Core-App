# HoloKai Frontend — RAG / Ollama / vector backends
# Copy to frontend/.env.local and adjust.

# Ollama (embeddings + optional persona voice)
OLLAMA_URL=http://localhost:11434
NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434
HOLAKAI_EMBED_MODEL=nomic-embed-text

# Vector backend: local | chroma | qdrant | auto
# local  = pure JSON cosine store (DEFAULT — no Docker, no chromadb npm)
# chroma = optional Chroma server (REST; set CHROMA_URL)
# qdrant = optional Qdrant REST (set QDRANT_URL)
# auto   = only probes backends with explicit URLs, else local
HOLAKAI_VECTOR_BACKEND=local

# Chat model for Vanguard persona (auto-picks an installed model if missing)
NEXT_PUBLIC_OLLAMA_MODEL=llama3.2

# Local pure-TS store path (default: frontend/.data/holokai-vectors.json)
# HOLAKAI_VECTOR_PATH=.data/holokai-vectors.json
HOLAKAI_COLLECTION=holokai-knowledge

# Optional Chroma (docker compose --profile chroma)
# HOLAKAI_VECTOR_BACKEND=chroma
# CHROMA_URL=http://localhost:8001

# Optional Qdrant (docker compose --profile qdrant-ollama)
# HOLAKAI_VECTOR_BACKEND=qdrant
# QDRANT_URL=http://localhost:6333
# HOLAKAI_EMBED_DIMS=768

# Python Civilization Core (Next rewrites /backend/* → this)
NEXT_PUBLIC_API_URL=http://localhost:8000
